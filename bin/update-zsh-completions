#!/bin/zsh

set -euo pipefail

repo_root="${0:A:h:h}"
completion_dir="$repo_root/zsh/completions"

mkdir -p "$completion_dir"

generate_completion() {
  local target_path="$1"
  shift

  local tmp_path="${target_path}.tmp"
  "$@" > "$tmp_path"
  chmod 0644 "$tmp_path"
  mv "$tmp_path" "$target_path"
  print -r -- "generated ${target_path:t}"
}

manage_generated_completion() {
  local command_name="$1"
  local completion_name="$2"
  shift 2

  local target_path="$completion_dir/$completion_name"

  if ! whence -p "$command_name" >/dev/null; then
    print -u2 -r -- "skipped ${completion_name}: command '$command_name' not found"
    return 0
  fi

  generate_completion "$target_path" "$@"
}

manage_generated_completion op _op op completion zsh
